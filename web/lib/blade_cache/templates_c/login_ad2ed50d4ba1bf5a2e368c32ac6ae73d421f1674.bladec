 <?php if($err_msg['0'] !=''): ?>
 <?php $__currentLoopData = $err_msg; $this->addLoop($__currentLoopData);$this->getFirstLoop();
 foreach($__currentLoopData as $msg): $loop = $this->incrementLoopIndices();  ?>
 <span style="color:red;"><?php echo \htmlentities($msg??'', ENT_QUOTES, 'UTF-8', false); ?></span><br>
 <?php endforeach; $this->popLoop(); $loop = $this->getFirstLoop(); ?>
 <?php endif; ?>

 <form name="login_form" action="index.php" method="post">
 <input type="hidden" name="page" value="<?php echo \htmlentities($page??'', ENT_QUOTES, 'UTF-8', false); ?>">
 <input type="hidden" name="exec" value="login">
 <div class="form-item">
 <label for="login_id"></label>
 <input type="text" name="login_id" id="login_id" value="<?php echo \htmlentities($login_id??'', ENT_QUOTES, 'UTF-8', false); ?>" autocomplete="off" required="required" placeholder="Email Address"></input>
 </div>
 <div class="form-item">
 <label for="login_pass"></label>
 <input type="password" name="login_pass" id="login_pass" value="<?php echo \htmlentities($login_pass??'', ENT_QUOTES, 'UTF-8', false); ?>" autocomplete="off" required="required" placeholder="Password"></input>
 </div>
 <div class="button-panel">
 <input type="submit" class="button" title="Sign In" __onclick="location.href='mypage.html'" value="ログイン"></input>
 </div>
 <div style="margin-top: 10px;">
 <span style="font-weight:bold;">初めてログインされる方</span><br>
 <span style="font-weight:bold;">パスワードをお忘れの方</span><br>
 <div style="padding-left:20px;">下記よりパスワード設定後ログインください。</div>
