 <!-- <?php /* ****************** 企業フィルター ****************** */ ?> -->
 <input type="text" name="syozoku_group_filter" placeholder="選択肢をフィルター" onKeyup="syozokuGroupFilter();"><br>
 選択肢フィルタに閲覧部署グループ名を入力（例:食品安全管理部等）後、プルダウン候補から閲覧部署グループ名を選択<br><br>
 <select id="hidden_syozoku_group_id_select" style="display:none;">
 <option value="">選択してください</option>
 <?php echo blade_html_options(['options' => $_conf_syozoku_group, 'selected' => $search_condition['syozoku_group_id']]); ?>

 </select>
 
 <script>
 function syozokuGroupFilter(){
 var filter = $('input[name="syozoku_group_filter"]').val();
 if(filter==''){
 $('select[name="syozoku_group_id"]').html( $("#hidden_syozoku_group_id_select").html() );
 }else{
 $('select[name="syozoku_group_id"]').html('');
 $('select[name="syozoku_group_id"]').append($("<option>").val('').text( '選択してください' ));
 $("#hidden_syozoku_group_id_select option").each(function(i){
 if($(this).text().indexOf(filter) != -1){
 $('select[name="syozoku_group_id"]').append($("<option>").val($(this).val()).text( $(this).text() ));
 }
 });
 }
 }
 </script>
 
 <!-- <?php /* ****************** /企業フィルター ****************** */ ?> -->

 <select name="syozoku_group_id" style="width:460px;" onchange="syozokuGroupSelect(this);">
 <option value="">選択してください</option>
 <?php echo blade_html_options(['options' => $_conf_syozoku_group]); ?>

 </select>
 </div>

 <div id="selected_syozoku_group">
 <?php $__currentLoopData = $syozoku_groups; $this->addLoop($__currentLoopData);$this->getFirstLoop();
 foreach($__currentLoopData as $syozoku_group): $loop = $this->incrementLoopIndices();  ?>
 <div class="pl-2"><?php echo \htmlentities($syozoku_group['szkgrp_name']??'', ENT_QUOTES, 'UTF-8', false); ?><input type="hidden" name="syozoku_group_ids[]" value="<?php echo $syozoku_group['szkgrp_id']; ?>"/><button class="delete_syozoku_group btn-danger ml-2">削除</button></div>
 <?php endforeach; $this->popLoop(); $loop = $this->getFirstLoop(); ?>
 </div>
 </div>

