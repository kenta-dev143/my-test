
<script>
function _regist(_mode){
 if(_mode =='delete'){
 if(window.confirm('本当に削除してもよろしいでしょうか？')){
 document.form_edit.mode.value=_mode;
 document.form_edit.submit();
 }
 }else{
 document.form_edit.mode.value=_mode;
 document.form_edit.submit();
 }
}

function syozokuGroupSelect(obj){
 var index = obj.selectedIndex;
 var value = obj.options[index].value;
 var name = obj.options[index].text;

 var selected = $('input[name="syozoku_group_ids[]"][value="' + value + '"]');

 if (selected.length > 0 || value == '') {
 return;
 }

 var div_syozoku = $('#selected_syozoku_group');
 var add_syozoku_div = $('<div>', {text: name, class: 'pl-2'});
 var add_syozoku_input = $('<input>',
 {
 type: 'hidden',
 name: 'syozoku_group_ids[]',
 value: value
 }
 );
 var add_delete_button = $('<button>', {text: '削除', class: 'delete_syozoku_group btn-danger ml-2'});
 add_delete_button.click(deleteSyozokuGroup);
 div_syozoku.append(add_syozoku_div);
 add_syozoku_div.append(add_syozoku_input);
 add_syozoku_div.append(add_delete_button);
}

function deleteSyozokuGroup() {
 $(this).parent().remove();
}

$(function () {
 $('.delete_syozoku_group').on('click', deleteSyozokuGroup);
});

</script>


<div class="inner_wrap">
 <?php if($err_msg['0'] !=''): ?>
 <div class="errArea">
 <?php $__currentLoopData = $err_msg; $this->addLoop($__currentLoopData);$this->getFirstLoop();
 foreach($__currentLoopData as $msg): $loop = $this->incrementLoopIndices();  ?>
 <?php echo \htmlentities($msg??'', ENT_QUOTES, 'UTF-8', false); ?><br>
 <?php endforeach; $this->popLoop(); $loop = $this->getFirstLoop(); ?>
 </div><br>
 <?php elseif($success_msg!=""): ?>
 <div class="successArea"><?php echo \htmlentities($success_msg??'', ENT_QUOTES, 'UTF-8', false); ?></div>
 <?php endif; ?>

